# The repo root's package.json only proxies scripts into apps/* — it has no
# dependencies and must never grow a lockfile. A stray root package-lock.json
# gives Turbopack two lockfiles and destabilizes its workspace-root inference:
# the dev server then writes chunks/manifests under two different roots and
# CSS/JS intermittently 404s ("styles in and out"). .gitignore already hides
# the stray file; this stops npm from creating it at all.
package-lock=false
